FROM node:22-alpine

WORKDIR /app

RUN apk add --no-cache openssl \
  && corepack enable

COPY . .

RUN pnpm install --frozen-lockfile \
  && pnpm --filter @repo/shared build \
  && pnpm --filter @repo/api prisma generate \
  && pnpm --filter @repo/api build

EXPOSE 4000

CMD ["pnpm", "--filter", "@repo/api", "start"]