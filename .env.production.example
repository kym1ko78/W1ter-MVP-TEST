# Domain and reverse proxy
APP_DOMAIN="chat.example.com"
API_DOMAIN="api.example.com"
LETSENCRYPT_EMAIL="admin@example.com"

# Database
POSTGRES_DB="messenger"
POSTGRES_USER="messenger_user"
POSTGRES_PASSWORD="change-me"
DATABASE_URL="postgresql://messenger_user:change-me@postgres:5432/messenger?schema=public"

# JWT
JWT_ACCESS_SECRET="replace-with-a-long-random-secret"
JWT_REFRESH_SECRET="replace-with-a-second-long-random-secret"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL_DAYS="7"

# API
API_PORT="4000"
API_CORS_ORIGIN="https://chat.example.com"
UPLOADS_DIR="/app/uploads"

# Web build args
NEXT_PUBLIC_API_URL="https://api.example.com"
NEXT_PUBLIC_SOCKET_URL="https://api.example.com"